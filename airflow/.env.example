# Airflow Core Settings
AIRFLOW_IMAGE_NAME=apache/airflow:2.8.1-python3.11
AIRFLOW_UID=50000

# Additional Airflow PIP dependencies (installed at container startup)
_PIP_ADDITIONAL_REQUIREMENTS=dbt-bigquery google-cloud-bigquery pandas

# Google Cloud Platform (GCP) Credentials & Paths
GCP_PROJECT_ID=ny-taxi-pipeline-2025
GCP_GCS_BUCKET=ny-taxi-raw-2025
GCP_BIGQUERY_DATASET=raw_nyc_taxi

# Airflow Google Cloud Connection Setup (assumes service-account.json is mounted)
AIRFLOW_CONN_GOOGLE_CLOUD_DEFAULT=google-cloud-platform://?key_path=%2Fopt%2Fairflow%2Fkeys%2Fgcp-service-account.json
